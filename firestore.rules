rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function householdPath(householdId) {
      return /databases/$(database)/documents/households/$(householdId);
    }

    function isHouseholdMember(householdId) {
      return signedIn()
        && exists(householdPath(householdId))
        && request.auth.uid in get(householdPath(householdId)).data.memberIds;
    }

    function isValidMember(member) {
      return member is map
        && member.displayName is string
        && member.displayName.size() > 0
        && member.displayName.size() <= 60
        && member.roleLabel is string
        && member.roleLabel.size() > 0
        && member.roleLabel.size() <= 40;
    }

    function isCreatingOwnHousehold() {
      return signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberIds == [request.auth.uid]
        && isValidMember(request.resource.data.members[request.auth.uid])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80
        && request.resource.data.roomPassword is string
        && request.resource.data.roomPassword.size() >= 4
        && request.resource.data.roomPassword.size() <= 40
        && request.resource.data.inviteCode is string
        && request.resource.data.inviteCode.matches('^[A-Z0-9]{6}$')
        && request.resource.data.monthlyBudget is number
        && request.resource.data.monthlyBudget >= 0
        && request.resource.data.monthlyIncome is number
        && request.resource.data.monthlyIncome >= 0
        && request.resource.data.committedExpenses is number
        && request.resource.data.committedExpenses >= 0
        && request.resource.data.savingsReserve is number
        && request.resource.data.savingsReserve >= 0
        && request.resource.data.categoryBudgets is map;
    }

    function isJoiningHousehold() {
      return signedIn()
        && !(request.auth.uid in resource.data.memberIds)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['memberIds', 'members', 'lastJoinInviteCode', 'lastJoinRoomPassword', 'updatedAt'])
        && request.resource.data.memberIds.hasAll(resource.data.memberIds)
        && request.auth.uid in request.resource.data.memberIds
        && request.resource.data.lastJoinInviteCode == resource.data.inviteCode
        && request.resource.data.lastJoinRoomPassword == resource.data.roomPassword
        && isValidMember(request.resource.data.members[request.auth.uid]);
    }

    function isBudgetUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'monthlyBudget',
          'monthlyIncome',
          'committedExpenses',
          'savingsReserve',
          'categoryBudgets',
          'updatedAt'
        ])
        && request.resource.data.monthlyBudget is number
        && request.resource.data.monthlyBudget >= 0
        && request.resource.data.monthlyBudget <= 10000000
        && request.resource.data.monthlyIncome is number
        && request.resource.data.monthlyIncome >= 0
        && request.resource.data.monthlyIncome <= 10000000
        && request.resource.data.committedExpenses is number
        && request.resource.data.committedExpenses >= 0
        && request.resource.data.committedExpenses <= 10000000
        && request.resource.data.savingsReserve is number
        && request.resource.data.savingsReserve >= 0
        && request.resource.data.savingsReserve <= 10000000
        && request.resource.data.categoryBudgets is map;
    }

    function isLegacyBudgetUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'monthlyBudget',
          'categoryBudgets',
          'updatedAt'
        ])
        && request.resource.data.monthlyBudget is number
        && request.resource.data.monthlyBudget >= 0
        && request.resource.data.monthlyBudget <= 10000000
        && request.resource.data.categoryBudgets is map;
    }

    function isValidPriority(priority) {
      return priority in ['P0', 'P1', 'P2', 'P3'];
    }

    function isValidStatus(status) {
      return status in [
        'pending',
        'approved',
        'declined',
        'needs_more_info',
        'buy_later',
        'purchased',
        'cancelled'
      ];
    }

    function isHttpsUrlOrNull(value) {
      return value == null || (value is string && value.matches('^https://.+'));
    }

    function hasValidRequestShape() {
      return request.resource.data.householdId is string
        && isHouseholdMember(request.resource.data.householdId)
        && request.resource.data.productName is string
        && request.resource.data.productName.size() > 0
        && request.resource.data.productName.size() <= 80
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.reason.size() <= 1000
        && isValidPriority(request.resource.data.priority)
        && isValidStatus(request.resource.data.status)
        && request.resource.data.expectedPrice is number
        && request.resource.data.expectedPrice >= 0
        && request.resource.data.expectedPrice <= 10000000
        && request.resource.data.maxBudget is number
        && request.resource.data.maxBudget >= 0
        && request.resource.data.maxBudget <= 10000000
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.category.size() <= 40
        && request.resource.data.links is list
        && request.resource.data.links.size() <= 5
        && isHttpsUrlOrNull(request.resource.data.image);
    }

    function isRequestCreator() {
      return request.resource.data.createdBy == request.auth.uid;
    }

    function isDecisionUpdate() {
      return request.resource.data.householdId == resource.data.householdId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'decisionReason',
          'decisionBy',
          'decisionAt',
          'updatedAt',
          'lastActivityAt',
          'lastActivityType'
        ])
        && isValidStatus(request.resource.data.status)
        && request.resource.data.decisionBy == request.auth.uid
        && request.resource.data.decisionReason is string
        && request.resource.data.decisionReason.size() <= 300;
    }

    function isCommentAggregateUpdate() {
      return request.resource.data.householdId == resource.data.householdId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'commentCount',
          'lastCommentBy',
          'lastCommentText',
          'lastActivityAt',
          'lastActivityType',
          'updatedAt'
        ])
        && request.resource.data.commentCount == resource.data.commentCount + 1
        && request.resource.data.lastCommentBy == request.auth.uid
        && request.resource.data.lastActivityType == 'comment'
        && request.resource.data.lastCommentText is string
        && request.resource.data.lastCommentText.size() <= 1000;
    }

    match /inviteCodes/{inviteCode} {
      allow read: if signedIn() && inviteCode.matches('^[A-Z0-9]{6}$');
      allow create: if signedIn()
        && request.resource.data.householdId is string
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if false;
    }

    match /households/{householdId} {
      allow get: if isHouseholdMember(householdId);
      allow list: if signedIn() && request.auth.uid in resource.data.memberIds;
      allow create: if isCreatingOwnHousehold();
      allow update: if isHouseholdMember(householdId) && (isBudgetUpdate() || isLegacyBudgetUpdate())
        || isJoiningHousehold();
      allow delete: if false;

      match /aiDecisionCache/{cacheId} {
        allow read: if isHouseholdMember(householdId);
        allow create, update: if isHouseholdMember(householdId)
          && request.resource.data.householdId == householdId
          && request.resource.data.payload is map
          && request.resource.data.result is map;
        allow delete: if false;
      }

      match /aiUsage/{monthKey} {
        allow read: if isHouseholdMember(householdId);
        allow create, update: if isHouseholdMember(householdId)
          && monthKey.matches('^[0-9]{4}-[0-9]{2}$')
          && request.resource.data.count is number
          && request.resource.data.count >= 0
          && request.resource.data.count <= 10
          && request.resource.data.limit == 10;
        allow delete: if false;
      }
    }

    match /tasks/{taskId} {
      allow read: if isHouseholdMember(resource.data.householdId);
      allow create: if hasValidRequestShape()
        && request.resource.data.status == 'pending'
        && isRequestCreator();
      allow update: if isHouseholdMember(resource.data.householdId)
        && (isDecisionUpdate() || isCommentAggregateUpdate());
      allow delete: if false;

      match /comments/{commentId} {
        allow read: if isHouseholdMember(get(/databases/$(database)/documents/tasks/$(taskId)).data.householdId);
        allow create: if isHouseholdMember(get(/databases/$(database)/documents/tasks/$(taskId)).data.householdId)
          && request.resource.data.householdId == get(/databases/$(database)/documents/tasks/$(taskId)).data.householdId
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000
          && isHttpsUrlOrNull(request.resource.data.image)
          && isHttpsUrlOrNull(request.resource.data.link);
        allow update, delete: if false;
      }
    }
  }
}
